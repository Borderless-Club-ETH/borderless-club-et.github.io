rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: allow read for authenticated users, write only for admin
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email in ['bamlakb.woldeyohannes@gmail.com', 'aynalemassefa.com@gmail.com'];
      allow update: if request.auth != null && (request.auth.token.email in ['bamlakb.woldeyohannes@gmail.com', 'aynalemassefa.com@gmail.com'] || 
        (request.auth.uid == userId && request.auth.token.email == resource.data.email));
    }

    // Questions collection: allow read for all authenticated users, write for coordinators and admin
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.token.email in ['bamlakb.woldeyohannes@gmail.com', 'aynalemassefa.com@gmail.com'] || 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canPostQuestions == true);
    }

    // Settings collection: allow read for all authenticated users, write for coordinators and admin
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.token.email in ['bamlakb.woldeyohannes@gmail.com', 'aynalemassefa.com@gmail.com'] || 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canPostQuestions == true);
    }

    // Allow read/write for other collections if authenticated (e.g., for leaderboard, etc.)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}